{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Worker": {
    "Login": {
      "Enabled": false,
      "ArtifactDirectory": "",
      "DevelopmentEnrollmentEnabled": false,
      "MaximumAccounts": 64,
      "MaximumSessions": 256,
      "SessionLifetimeMinutes": 15
