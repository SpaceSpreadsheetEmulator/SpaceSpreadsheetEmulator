{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Gateway": {
    "Backplane": {
      "Enabled": true,
      "Address": "http://127.0.0.1:5199",
      "CoordinatorAddress": "http://127.0.0.1:5216",
      "GatewayId": "gateway-topology",
      "RouteCacheSeconds": 5
    },
    "LocalClientEdge": {
      "Enabled": false
    },
    "Tcp": {
      "Enabled": true,
      "Address": "127.0.0.1",
      "Port": 26000,
      "SoftConnectionLimit": 256,
      "OutboundQueueCapacity": 64
    }
  }
}
