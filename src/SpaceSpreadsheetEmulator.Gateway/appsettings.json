{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Gateway": {
    "Compatibility": {
      "CapturedStartupDataDirectory": ""
    },
    "Backplane": {
      "Enabled": false,
      "Address": "http://127.0.0.1:5199",
      "CoordinatorAddress": "http://127.0.0.1:5216",
      "GatewayId": "gateway-local",
      "RouteCacheSeconds": 5
    },
    "LocalClientEdge": {
      "Enabled": false,
      "Address": "127.0.0.1",
      "ProxyPort": 26002,
      "TlsPort": 26003,
      "MaximumProxyConnections": 32,
      "TrustDirectory": "",
      "GatewayCertificateDirectory": "_local/development-certificates"
    },
    "Tcp": {
      "Enabled": false,
      "Address": "127.0.0.1",
      "Port": 26000,
      "SoftConnectionLimit": 256,
      "OutboundQueueCapacity": 64
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Management": {
        "Url": "http://127.0.0.1:5287",
        "Protocols": "Http1"
      }
    }
  },
  "AllowedHosts": "*"
}
